{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/hubspot/deal",
      "dest": "/api/hubspot/deal.js"
    },
    {
      "src": "/api/hubspot/company",
      "dest": "/api/hubspot/company.js"
    },
    {
      "src": "/api/hubspot/submit",
      "dest": "/api/hubspot/submit.js"
    },
    {
      "src": "/api/hubspot/attach-pdf",
      "dest": "/api/hubspot/attach-pdf.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
